---
---
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid-lines"></div>
  <div class="hero-split">
    <div class="hero-content hero-copy">
      <div class="hero-tag">Available for opportunities · Roma, Italia</div>
      <h1 class="hero-name">
        <span class="line"><span class="word">Design</span></span>
        <span class="line"><span class="word accent">Engineer</span></span>
        <span class="line"><span class="word stroke">&amp; AI</span></span>
      </h1>
      <p class="hero-desc">
        Frontend developer con forte orientamento verso UX/UI Design e AI — creo interfacce moderne, animate e intelligenti.
      </p>
      <div class="hero-ctas">
        <a href="#work" class="btn-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Vedi i Progetti
        </a>
        <a href="#contact" class="btn-secondary">Parliamo</a>
      </div>
    </div>
    <div class="hero-stage">
      <div class="hero-stage-wrap">
        <div class="hero-stage-glow"></div>
        <div class="hero-stage-grid"></div>
        <canvas id="heroCanvas" class="hero-stage-canvas" aria-hidden="true"></canvas>
        <div class="hero-stage-label">Readable <strong>creative core</strong></div>
        <div class="hero-stage-badge">UI · Motion · <strong>LLM</strong></div>
        <button class="orb-help" type="button" aria-expanded="false" aria-controls="orbTooltip">i</button>
        <div class="hero-stage-note" id="orbTooltip" role="tooltip">
          <div class="orb-note-bar"></div>
          <div class="orb-note-inner">
            <div class="tiny">Creative System Orb</div>
            <div class="big">Design × Frontend × AI</div>
            <div class="small">Un ecosistema visivo che rende leggibili le aree che presidio: interfacce, motion, sistemi e intelligenza artificiale.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="hero-scroll">
    <div class="scroll-arrow"><span></span><span></span><span></span></div>
    Scroll
  </div>
</section>
