---
---
<section id="skills">
  <div class="skills-inner">

    <div class="skills-header">
      <div>
        <p class="section-label">Stack &amp; Expertise</p>
        <h2 class="section-title" style="margin-top:var(--space-3)">Skills &amp;<br /><em>Tools.</em></h2>
      </div>
    </div>

    <div class="skills-stage-wrap">

      <div class="skills-cats skills-cats--left">
        <div class="cat-block">
          <div class="cat-name"><span class="cat-name-rule"></span><span>Frontend</span></div>
          <div class="cat-skills">
            <span class="cat-skill">React.js /</span>
            <span class="cat-skill">TypeScript /</span>
            <span class="cat-skill">JavaScript /</span>
            <span class="cat-skill">HTML / CSS /</span>
            <span class="cat-skill">Tailwind /</span>
            <span class="cat-skill">GSAP /</span>
            <span class="cat-skill">Vite /</span>
          </div>
        </div>
        <div class="cat-block">
          <div class="cat-name"><span class="cat-name-rule"></span><span>Design</span></div>
          <div class="cat-skills">
            <span class="cat-skill">Figma /</span>
            <span class="cat-skill">UX / UI /</span>
            <span class="cat-skill">Wireframing /</span>
            <span class="cat-skill">Design Systems /</span>
            <span class="cat-skill">Microinterazioni /</span>
          </div>
        </div>
        <div class="cat-block">
          <div class="cat-name"><span class="cat-name-rule"></span><span>Lingue</span></div>
          <div class="cat-skills">
            <span class="cat-skill">Italiano — Madrelingua /</span>
            <span class="cat-skill">Inglese — Fluente /</span>
            <span class="cat-skill">Spagnolo — Fluente /</span>
          </div>
        </div>
      </div>

      <div class="skills-orb" id="stage">
        <p class="skills-meta skills-meta--orb">Trascina i loghi ↓</p>
        <svg id="connSvg"></svg>
        <div class="ellipse-wrap" id="ellipseEl"></div>
      </div>

      <div class="skills-cats skills-cats--right">
        <div class="cat-block">
          <div class="cat-name"><span class="cat-name-rule"></span><span>AI &amp; LLM</span></div>
          <div class="cat-skills">
            <span class="cat-skill">/ Claude API</span>
            <span class="cat-skill">/ OpenAI API</span>
            <span class="cat-skill">/ Vercel AI SDK</span>
            <span class="cat-skill">/ LLM Integration</span>
            <span class="cat-skill">/ Prompt Eng.</span>
          </div>
        </div>
        <div class="cat-block">
          <div class="cat-name"><span class="cat-name-rule"></span><span>Backend</span></div>
          <div class="cat-skills">
            <span class="cat-skill">/ Java</span>
            <span class="cat-skill">/ Python</span>
            <span class="cat-skill">/ Node.js</span>
            <span class="cat-skill">/ SQL</span>
            <span class="cat-skill">/ Cloudflare</span>
            <span class="cat-skill">/ Vercel</span>
          </div>
        </div>
        <div class="cat-block">
          <div class="cat-name"><span class="cat-name-rule"></span><span>Infrastruttura</span></div>
          <div class="cat-skills">
            <span class="cat-skill">/ Linux</span>
            <span class="cat-skill">/ VMware vSphere</span>
            <span class="cat-skill">/ Power Platform</span>
            <span class="cat-skill">/ GitHub</span>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>
